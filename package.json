{
  "name": "app-hub",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "init": "node scripts/init.js",
    "init:core": "node scripts/init.js --only-core",
    "init:skip-clean": "node scripts/init.js --skip-clean",
    "init:skip-build": "node scripts/init.js --skip-build",
    "start": "cd hub-server && npm start",
    "start:dev": "cd hub-server && npm run dev",
    "build:all": "node scripts/build-all.js",
    "build:sample": "node scripts/build-all.js sample 10",
    "check:port": "node scripts/check-port.js",
    "check:health": "node scripts/health-check.js",
    "verify:deploy": "node scripts/verify-deploy.js"
  },
  "workspaces": [
    "packages/*",
    "apps/*/*",
    "lobby-web",
    "hub-server"
  ],
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14"
  }
}
